# ──────────────────────────────────────────
# CyberSentinel - Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env and fill in values.
# DO NOT commit the .env file to version control.

# Email Reporting (Optional)
SENTINEL_SMTP_SERVER=smtp.gmail.com
SENTINEL_SMTP_PORT=587
SENTINEL_EMAIL_SENDER=your-email@gmail.com
SENTINEL_EMAIL_PASSWORD=your-app-password
SENTINEL_EMAIL_RECIPIENT=recipient@example.com
